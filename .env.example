# RentMaster backend (rent-master-pwa) — copy to .env.local and fill in real values.
# .env.local is gitignored; NEVER commit real secrets.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Full DB access — must never reach the browser or a client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Tenant auth (recommended for prod) ---
# HMAC secret for backend-signed tenant JWTs. If unset, falls back to the
# service-role key. Set a dedicated strong random value in production.
TENANT_JWT_SECRET=

# --- CORS (required in prod) ---
# Comma-separated list of real browser origins allowed to call the API.
# Defaults to localhost dev ports if unset.
ALLOWED_ORIGINS=https://your-frontend-domain.com

# --- Web Push / VAPID (required for BROWSER push notifications) ---
# Generate once: npx web-push generate-vapid-keys
# The PUBLIC key must ALSO be set (same value) on the frontend as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@pmp.com

# --- FCM / Firebase (required for the native ANDROID app push) ---
# The full Firebase service-account JSON, as a SINGLE-LINE string (Server-only secret).
# Firebase console -> Project settings -> Service accounts -> Generate new private key.
# Without it, Android push is skipped (browser web push still works).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# --- Cron (required for SCHEDULED rent reminders) ---
# Any strong random string. Gates /api/cron/reminders. Vercel Cron sends it automatically as
# `Authorization: Bearer <CRON_SECRET>`. Without it the cron endpoint returns 401 (no delivery).
CRON_SECRET=your-strong-random-cron-secret
